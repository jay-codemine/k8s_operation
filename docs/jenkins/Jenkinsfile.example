// Jenkinsfile 示例 - 适配 containerd 运行时
// 此文件放置于 Git 仓库根目录，供平台触发使用
// 
// 关键点：
// 1. 使用 nerdctl/buildah 替代 docker build（适配 containerd）
// 2. 构建完成后回调平台接口，形成闭环
// 3. 支持平台传入的构建参数

pipeline {
    agent {
        kubernetes {
            // 使用 Kubernetes Pod 作为构建节点（适配 containerd）
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: builder
    image: moby/buildkit:latest
    command: ['cat']
    tty: true
    securityContext:
      privileged: true
    volumeMounts:
    - name: buildkit-socket
      mountPath: /run/buildkit
  - name: kubectl
    image: bitnami/kubectl:latest
    command: ['cat']
    tty: true
  volumes:
  - name: buildkit-socket
    emptyDir: {}
'''
        }
    }
    
    // 平台传入的参数
    parameters {
        string(name: 'GIT_REPO', defaultValue: '', description: 'Git 仓库地址')
        string(name: 'GIT_BRANCH', defaultValue: 'main', description: 'Git 分支')
        string(name: 'IMAGE_REPO', defaultValue: '', description: '镜像仓库地址')
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: '镜像标签')
        string(name: 'NAMESPACE', defaultValue: 'default', description: 'K8s 命名空间')
        string(name: 'DEPLOYMENT_NAME', defaultValue: '', description: 'Deployment 名称')
        string(name: 'CONTAINER_NAME', defaultValue: '', description: '容器名称')
        string(name: 'PLATFORM_CALLBACK_URL', defaultValue: '', description: '平台回调地址')
        string(name: 'PLATFORM_TOKEN', defaultValue: '', description: '平台认证Token')
        string(name: 'PIPELINE_ID', defaultValue: '', description: '平台流水线ID')
    }
    
    environment {
        // 镜像仓库认证（从 Jenkins Credentials 获取）
        REGISTRY_CREDS = credentials('harbor-registry')
        // kubeconfig（从 Jenkins Credentials 获取）
        KUBECONFIG_CREDS = credentials('k8s-kubeconfig')
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo "📦 拉取代码: ${params.GIT_REPO} @ ${params.GIT_BRANCH}"
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "*/${params.GIT_BRANCH}"]],
                    userRemoteConfigs: [[url: params.GIT_REPO]]
                ])
                
                script {
                    env.GIT_COMMIT = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    echo "Git Commit: ${env.GIT_COMMIT}"
                }
            }
        }
        
        stage('Build Image') {
            steps {
                container('builder') {
                    echo "🔨 构建镜像: ${params.IMAGE_REPO}:${params.IMAGE_TAG}"
                    
                    // 使用 buildkit 构建镜像（适配 containerd）
                    sh '''
                        buildctl build \
                            --frontend dockerfile.v0 \
                            --local context=. \
                            --local dockerfile=. \
                            --output type=image,name=${IMAGE_REPO}:${IMAGE_TAG},push=true \
                            --export-cache type=inline \
                            --import-cache type=registry,ref=${IMAGE_REPO}:buildcache
                    '''
                }
            }
        }
        
        stage('Deploy to K8s') {
            steps {
                container('kubectl') {
                    echo "🚀 部署到 K8s: ${params.NAMESPACE}/${params.DEPLOYMENT_NAME}"
                    
                    // 写入 kubeconfig
                    writeFile file: '/tmp/kubeconfig', text: env.KUBECONFIG_CREDS
                    
                    // 更新 Deployment 镜像
                    sh """
                        export KUBECONFIG=/tmp/kubeconfig
                        kubectl set image deployment/${params.DEPLOYMENT_NAME} \
                            ${params.CONTAINER_NAME}=${params.IMAGE_REPO}:${params.IMAGE_TAG} \
                            -n ${params.NAMESPACE}
                        
                        # 等待 rollout 完成
                        kubectl rollout status deployment/${params.DEPLOYMENT_NAME} \
                            -n ${params.NAMESPACE} \
                            --timeout=300s
                    """
                }
            }
        }
    }
    
    post {
        success {
            echo "✅ 构建部署成功，回调平台..."
            script {
                if (params.PLATFORM_CALLBACK_URL) {
                    httpRequest(
                        url: params.PLATFORM_CALLBACK_URL,
                        httpMode: 'POST',
                        contentType: 'APPLICATION_JSON',
                        customHeaders: [
                            [name: 'Authorization', value: "Bearer ${params.PLATFORM_TOKEN}"],
                            [name: 'Content-Type', value: 'application/json']
                        ],
                        requestBody: """{
                            "job_name": "${env.JOB_NAME}",
                            "build_number": ${env.BUILD_NUMBER},
                            "status": "SUCCESS",
                            "duration": ${currentBuild.duration / 1000},
                            "message": "构建部署成功",
                            "git_commit": "${env.GIT_COMMIT}",
                            "image": "${params.IMAGE_REPO}:${params.IMAGE_TAG}"
                        }""",
                        validResponseCodes: '200'
                    )
                }
            }
        }
        failure {
            echo "❌ 构建部署失败，回调平台..."
            script {
                if (params.PLATFORM_CALLBACK_URL) {
                    httpRequest(
                        url: params.PLATFORM_CALLBACK_URL,
                        httpMode: 'POST',
                        contentType: 'APPLICATION_JSON',
                        customHeaders: [
                            [name: 'Authorization', value: "Bearer ${params.PLATFORM_TOKEN}"],
                            [name: 'Content-Type', value: 'application/json']
                        ],
                        requestBody: """{
                            "job_name": "${env.JOB_NAME}",
                            "build_number": ${env.BUILD_NUMBER},
                            "status": "FAILURE",
                            "duration": ${currentBuild.duration / 1000},
                            "message": "构建部署失败: ${currentBuild.result}"
                        }""",
                        validResponseCodes: '200'
                    )
                }
            }
        }
        aborted {
            echo "⏹️ 构建被中止，回调平台..."
            script {
                if (params.PLATFORM_CALLBACK_URL) {
                    httpRequest(
                        url: params.PLATFORM_CALLBACK_URL,
                        httpMode: 'POST',
                        contentType: 'APPLICATION_JSON',
                        customHeaders: [
                            [name: 'Authorization', value: "Bearer ${params.PLATFORM_TOKEN}"],
                            [name: 'Content-Type', value: 'application/json']
                        ],
                        requestBody: """{
                            "job_name": "${env.JOB_NAME}",
                            "build_number": ${env.BUILD_NUMBER},
                            "status": "ABORTED",
                            "duration": ${currentBuild.duration / 1000},
                            "message": "构建被中止"
                        }""",
                        validResponseCodes: '200'
                    )
                }
            }
        }
    }
}
